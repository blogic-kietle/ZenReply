# ============================================================
# ZenReply Backend - Environment Variables
# Copy this file to .env and fill in your values.
#
# Architecture: User Token (xoxp-) only.
# No Bot Token or App Token needed.
# ZenReply uses each user's own Slack token to send messages.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=ZenReply
APP_VERSION=1.0.0
APP_ENV=development          # development | production
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:4200
LOG_LEVEL=info               # debug | info | warn | error

# ── PostgreSQL ────────────────────────────────────────────────
# Option A: individual fields
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=zenreply
POSTGRES_DB=zenreply
POSTGRES_SSLMODE=disable

# Option B: full DSN (overrides individual fields)
# DATABASE_URL=postgres://admin:zenreply@localhost:5432/zenreply?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────
# Option A: individual fields
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=zenreply
REDIS_DB=0

# Option B: full URL (overrides individual fields)
# REDIS_URL=redis://:zenreply@localhost:6379

# ── Slack ─────────────────────────────────────────────────────
# Create a Slack App at https://api.slack.com/apps
# Under "OAuth & Permissions" add these User Token Scopes:
#   chat:write, im:history, im:read, mpim:history, mpim:read,
#   channels:history, groups:history, users:read, users:read.email
# Under "Event Subscriptions" subscribe to: message.im, message.mpim
# Enable "Distribute App" for multi-workspace support.
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# OAuth redirect URL — must match your Slack App's redirect URL exactly
SLACK_REDIRECT_URL=http://localhost:8080/api/v1/slack/callback

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-random-secret-in-production
JWT_EXPIRATION=24h
