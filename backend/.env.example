# ============================================================
# ZenReply Backend - Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=ZenReply
APP_VERSION=1.0.0
APP_ENV=development          # development | production
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:4200
LOG_LEVEL=info               # debug | info | warn | error

# ── PostgreSQL ────────────────────────────────────────────────
# Option A: individual fields
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=zenreply
POSTGRES_DB=zenreply
POSTGRES_SSLMODE=disable

# Option B: full DSN (overrides individual fields)
# DATABASE_URL=postgres://admin:zenreply@localhost:5432/zenreply?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────
# Option A: individual fields
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=zenreply
REDIS_DB=0

# Option B: full URL (overrides individual fields)
# REDIS_URL=redis://:zenreply@localhost:6379

# ── Slack ─────────────────────────────────────────────────────
# From your Slack App settings at https://api.slack.com/apps
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# App-Level Token (xapp-...) — required for Socket Mode
SLACK_APP_TOKEN=xapp-1-...

# Bot Token (xoxb-...) — required for sending messages
SLACK_BOT_TOKEN=xoxb-...

# HMAC secret for legacy webhook verification (optional)
HMAC_SECRET=your-hmac-secret

# OAuth redirect URL — must match your Slack App's redirect URL
SLACK_REDIRECT_URL=http://localhost:8080/api/v1/slack/callback

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-random-secret-in-production
JWT_EXPIRATION=24h
