# ============================================================
# ZenReply — Root Environment Variables (for docker-compose)
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Architecture: User Token (xoxp-) only.
# No Bot Token or App Token needed.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=production
APP_PORT=8080
APP_BASE_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com
LOG_LEVEL=info
RESTART_POLICY=unless-stopped

# ── PostgreSQL ────────────────────────────────────────────────
DB_USER=admin
DB_PASSWORD=change-me-strong-password
DB_NAME=zenreply
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong-password
REDIS_PORT=6379

# ── Slack ─────────────────────────────────────────────────────
# Create a Slack App at https://api.slack.com/apps
# User Token Scopes needed: chat:write, im:history, im:read,
#   mpim:history, mpim:read, channels:history, groups:history,
#   users:read, users:read.email
# Events to subscribe: message.im, message.mpim
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_REDIRECT_URL=https://your-domain.com/api/v1/slack/callback

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-random-secret-minimum-32-chars
JWT_EXPIRATION=24h
